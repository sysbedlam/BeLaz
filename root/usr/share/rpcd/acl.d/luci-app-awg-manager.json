{
	"luci-app-awg-manager": {
		"description": "Grant access to BeLaz Manager",
		"read": {
			"file": {
				"/etc/awg-manager": [ "list" ],
				"/etc/awg-manager/*": [ "read" ],
				"/etc/awg-manager/servers": [ "list" ],
				"/etc/awg-manager/servers/*": [ "read", "list" ],
				"/etc/awg-manager/servers/*/*": [ "read", "list" ],
				"/etc/awg-manager/servers/*/clients/*": [ "read" ],
				"/usr/bin/awg-manager-backend": [ "exec" ],
				"/usr/bin/awg-manager-backend *": [ "exec" ],
				"/usr/bin/awg-healthcheck": [ "exec" ],
				"/usr/bin/awg-routing": [ "exec" ],
				"/usr/bin/awg-routing *": [ "exec" ]
			}
		},
		"write": {
			"file": {
				"/etc/awg-manager/servers/*/clients/*": [ "write" ],
				"/etc/awg-manager/routing.json": [ "write" ],
				"/etc/awg-manager/address-lists.json": [ "write" ],
				"/usr/bin/awg-manager-backend": [ "exec" ],
				"/usr/bin/awg-manager-backend *": [ "exec" ],
				"/usr/bin/awg-healthcheck": [ "exec" ],
				"/usr/bin/awg-routing": [ "exec" ],
				"/usr/bin/awg-routing *": [ "exec" ]
			}
		}
	}
}
